<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.com.example.javainterface.LoginController">
   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label contentDisplay="TOP" text="EngenTech">
               <font>
                  <Font name="System Bold Italic" size="36.0" />
               </font>
            </Label>
            <TextField fx:id="txtUsuario" maxHeight="30.0" maxWidth="250.0" minHeight="35.0" minWidth="50.0" prefHeight="25.0" prefWidth="200.0" promptText="Usuario">
               <VBox.margin>
                  <Insets bottom="10.0" top="30.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="emailUsuario" maxHeight="30.0" maxWidth="250.0" minHeight="35.0" minWidth="50.0" prefHeight="25.0" prefWidth="200.0" promptText="Email">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="passUsuario" maxHeight="30.0" maxWidth="250.0" minHeight="35.0" minWidth="50.0" prefHeight="25.0" prefWidth="200.0" promptText="Senha">
               <VBox.margin>
                  <Insets bottom="15.0" />
               </VBox.margin>
            </TextField>
            <Button mnemonicParsing="false" onAction="#onLoginButtonClick" text="Login">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
            <Label fx:id="txtMessage">
               <VBox.margin>
                  <Insets top="25.0" />
               </VBox.margin>
            </Label>
         </children>
      </VBox>
   </center>
</BorderPane>
